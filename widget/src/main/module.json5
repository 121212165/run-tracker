{
  "module": {
    "name": "widget",
    "type": "form",
    "description": "$string:module_desc",
    "mainElement": "",
    "deviceTypes": ["phone", "tablet"],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
    "extensionAbilities": [
      {
        "name": "RunTrackerWidget",
        "srcEntry": "./ets/widget/pages/RunTrackerWidget.ets",
        "description": "$string:widget_desc",
        "icon": "$media:app_icon",
        "label": "$string:widget_label",
        "type": "form",
        "exported": true,
        "formConfig": {
          "name": "runTracker",
          "displayName": "$string:widget_display_name",
          "description": "$string:widget_desc",
          "formConfigAbility": "",
          "src": "./ets/widget/pages/RunTrackerWidget.ets",
          "uiSyntax": "arkts",
          "window": {
            "designWidth": 720,
            "autoDesignWidth": true
          },
          "colorMode": "auto",
          "isDefault": true,
          "updateEnabled": true,
          "scheduledUpdateTime": "10:30",
          "updateDuration": 1,
          "defaultDimension": "2*2",
          "supportDimensions": ["1*2", "2*2", "2*4", "4*4"]
        }
      }
    ]
  }
}
